      "credentials": [{ "type": "password", "value": "Test@1234", "temporary": false }],
      "realmRoles": ["finance"]
    },
    {
      "username": "management",
      "email": "management@procurehub.local",
      "firstName": "Carol",
      "lastName": "Management",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Test@1234", "temporary": false }],
      "realmRoles": ["management"]
    },
    {
      "username": "vendor_admin",
      "email": "vendor_admin@procurehub.local",
      "firstName": "Vendor",
      "lastName": "Admin",
      "enabled": true,
      "emailVerified": true,
      "credentials": [{ "type": "password", "value": "Test@1234", "temporary": false }],
      "realmRoles": ["vendor_admin"]
    },
    {
      "username": "vendor_staff",
      "email": "vendor_staff@procurehub.local",
      "firstName": "Vendor",
